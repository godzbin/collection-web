{
  "name": "collection-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:electron": "vue-tsc && vite build && electron-builder --config electron-builder.json5 --publish=never",
    "build:production": "cross-env NODE_ENV=production npm run build:electron",
    "build:win": "vue-tsc && vite build && electron-builder --win --config electron-builder.json5 --publish=never",
    "preview": "vite preview"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "echarts": "^6.0.0",
    "vue": "^3.4.21",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  },
  "build": {
    "appId": "com.yourcompany.collection-web",
    "productName": "Collection Web",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.26"
  },
  "main": "dist-electron/main.js"
}
